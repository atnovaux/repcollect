#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../lib/engagement.sh"

OUTPUT_DIR=$(ensure_engagement_dir recon) || exit 1

ARGS=()
skip_next=0
for arg in "$@"; do
    if [[ $skip_next -eq 1 ]]; then skip_next=0; continue; fi
    if [[ "$arg" == "--output-dir" ]]; then skip_next=1; continue; fi
    ARGS+=("$arg")
done

CANVASS_SCRIPT="$HOME/tools/canvass/brief.py"
VENV_PYTHON="$HOME/tools/pytools_venv/bin/python3"

if [[ ! -f "$CANVASS_SCRIPT" ]]; then
    echo "error: canvass brief.py not found at $CANVASS_SCRIPT. run install.sh." >&2
    exit 1
fi

echo "[repkit] canvass output -> $OUTPUT_DIR/" >&2
exec "$VENV_PYTHON" "$CANVASS_SCRIPT" --output-dir "$OUTPUT_DIR/" "${ARGS[@]}"
