#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../lib/engagement.sh"

OUTPUT_DIR=$(ensure_engagement_dir recon) || exit 1

ARGS=()
skip_next=0
for arg in "$@"; do
    if [[ $skip_next -eq 1 ]]; then skip_next=0; continue; fi
    if [[ "$arg" == "--output" || "$arg" == "-o" ]]; then skip_next=1; continue; fi
    ARGS+=("$arg")
done

CANVASS_BIN="$HOME/tools/pytools_venv/bin/canvass"
CANVASS_SCRIPT="$HOME/tools/canvass/canvass.py"
VENV_PYTHON="$HOME/tools/pytools_venv/bin/python3"

echo "[repkit] canvass output -> $OUTPUT_DIR/" >&2
if [[ -x "$CANVASS_BIN" ]]; then
    exec "$CANVASS_BIN" --output "$OUTPUT_DIR/" "${ARGS[@]}"
elif [[ -f "$CANVASS_SCRIPT" ]]; then
    exec "$VENV_PYTHON" "$CANVASS_SCRIPT" --output "$OUTPUT_DIR/" "${ARGS[@]}"
else
    echo "error: canvass not found. run install.sh." >&2
    exit 1
fi
