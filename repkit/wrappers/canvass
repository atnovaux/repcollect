#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../lib/engagement.sh"

OUTPUT_DIR=$(ensure_engagement_dir recon) || exit 1

ARGS=()
skip_next=0
for arg in "$@"; do
    if [[ $skip_next -eq 1 ]]; then skip_next=0; continue; fi
    if [[ "$arg" == "--output" || "$arg" == "-o" ]]; then skip_next=1; continue; fi
    ARGS+=("$arg")
done

echo "[repkit] canvass output -> $OUTPUT_DIR/" >&2
exec canvass --output "$OUTPUT_DIR/" "${ARGS[@]}"
