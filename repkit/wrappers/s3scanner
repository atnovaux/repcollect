#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../lib/engagement.sh"

OUTPUT_DIR=$(ensure_engagement_dir s3scanner) || exit 1
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
OUTFILE="$OUTPUT_DIR/s3scanner_${TIMESTAMP}.json"

# Strip any -json flags from operator args (wrapper always forces JSON)
ARGS=()
for arg in "$@"; do
    [[ "$arg" == "-json" ]] && continue
    ARGS+=("$arg")
done

echo "[repkit] s3scanner output -> $OUTFILE" >&2
s3scanner -json "${ARGS[@]}" | tee "$OUTFILE"
exit ${PIPESTATUS[0]}
