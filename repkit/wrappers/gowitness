#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../lib/engagement.sh"

OUTPUT_DIR=$(ensure_engagement_dir gowitness) || exit 1
mkdir -p "$OUTPUT_DIR/screenshots"

ARGS=()
skip_next=0
skip_next_value=0
for arg in "$@"; do
    if [[ $skip_next_value -eq 1 ]]; then skip_next_value=0; continue; fi
    case "$arg" in
        --screenshot-path|--destination|--db-path|--write-db-uri|-s)
            skip_next_value=1; continue ;;
        --write-db|--write-jsonl|--write-csv|--write-screenshots)
            continue ;;
    esac
    ARGS+=("$arg")
done

echo "[repkit] gowitness output -> $OUTPUT_DIR/" >&2
"$HOME/go/bin/gowitness" \
    "${ARGS[@]}" \
    --screenshot-path "$OUTPUT_DIR/screenshots/" \
    --write-db \
    --write-db-uri "sqlite://$OUTPUT_DIR/gowitness.sqlite3" \
    --write-jsonl \
    --write-jsonl-file "$OUTPUT_DIR/gowitness.jsonl"
exit $?
